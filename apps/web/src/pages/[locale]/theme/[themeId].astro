---
import Layout from '@/layouts/Layout.astro'
import { ThemeProvider } from '@clinro/ui/theme'
import { themes } from '@clinro/ui/theme'
import { getTranslator } from '@clinro/i18n/server'

const { locale, themeId } = Astro.params
const t = getTranslator(locale as 'ro' | 'en')

// Get the requested theme
const theme = themes.find(t => t.id === themeId) || themes[0]
---

<Layout title={`${theme.name} - Theme Preview`} locale={locale}>
  <ThemeProvider initialTheme={theme.id} isTenantPage={true}>
    <main class="min-h-screen bg-[var(--color-bg)] flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
      {/* Theme Preview Header */}
      <div class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-surface)]/80 backdrop-blur border-b border-[var(--color-border)]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <div>
            <h1 class="text-lg font-semibold text-[var(--color-fg)]">{theme.name}</h1>
            <p class="text-sm text-[var(--color-muted)]">{theme.description}</p>
          </div>
          <a
            href={`/${locale}`}
            class="px-4 py-2 text-sm border border-[var(--color-border)] rounded hover:bg-[var(--color-bg)] transition"
          >
            Back to Home
          </a>
        </div>
      </div>

      {/* Theme Preview Content */}
      <div class="w-full max-w-2xl mx-auto pt-24 space-y-8">
        {/* Typography Preview */}
        <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8">
          <h2 class="text-sm font-medium text-[var(--color-muted)] mb-4">Typography</h2>
          <p class="text-display-9xl font-display text-[var(--color-fg)] mb-4">
            Aa
          </p>
          <h1 class="text-display-5xl font-display text-[var(--color-fg)] mb-2">
            {theme.name}
          </h1>
          <p class="text-display-lg text-[var(--color-muted)]">
            This is a preview of the {theme.name} theme. It features {theme.fonts.display.family} for headlines and {theme.fonts.body.family} for body text.
          </p>
        </section>

        {/* Colors Preview */}
        <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8">
          <h2 class="text-sm font-medium text-[var(--color-muted)] mb-4">Color Palette</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {Object.entries(theme.colors).map(([name, color]) => (
              <div key={name}>
                <div
                  class="w-full aspect-square rounded border border-[var(--color-border)] mb-2"
                  style={{ backgroundColor: color }}
                />
                <p class="text-xs text-[var(--color-muted)]">{name}</p>
                <p class="text-xs font-mono text-[var(--color-muted)]">{color}</p>
              </div>
            ))}
          </div>
        </section>

        {/* Components Preview */}
        <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8">
          <h2 class="text-sm font-medium text-[var(--color-muted)] mb-4">Components</h2>
          <div class="space-y-4">
            {/* Buttons */}
            <div class="flex flex-wrap gap-4">
              <button class="px-4 py-2 bg-[var(--color-primary)] text-[var(--color-bg)] rounded font-medium">
                Primary Button
              </button>
              <button class="px-4 py-2 border border-[var(--color-border)] text-[var(--color-fg)] rounded font-medium">
                Secondary Button
              </button>
              <button class="px-4 py-2 text-[var(--color-muted)] hover:text-[var(--color-fg)] rounded font-medium">
                Ghost Button
              </button>
            </div>

            {/* Inputs */}
            <div>
              <input
                type="text"
                placeholder="Enter your email"
                class="w-full px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] text-[var(--color-fg)] rounded focus:outline-none focus:border-[var(--color-primary)]"
              />
            </div>

            {/* Card */}
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded p-4">
              <h3 class="text-display-xl font-display text-[var(--color-fg)] mb-2">Card Title</h3>
              <p class="text-[var(--color-muted)]">
                This is how a card looks with the {theme.name} theme.
              </p>
            </div>
          </div>
        </section>

        {/* Theme Motifs */}
        {theme.motifs.length > 0 && (
          <section class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-8">
            <h2 class="text-sm font-medium text-[var(--color-muted)] mb-4">Visual Motifs</h2>
            <div class="flex flex-wrap gap-2">
              {theme.motifs.map(motif => (
                <span
                  key={motif}
                  class="px-3 py-1 bg-[var(--color-bg)] border border-[var(--color-border)] rounded text-sm text-[var(--color-fg)]"
                >
                  {motif}
                </span>
              ))}
            </div>
          </section>
        )}
      </div>
    </main>
  </ThemeProvider>
</Layout>
