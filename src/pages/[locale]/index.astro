---
import Layout from '@/layouts/Layout.astro'
import { SUPPORTED_LOCALES, configureI18n, type Locale } from '@/i18n/config'

interface Props {
  locale: string
}

// Generate static paths for supported locales
export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => {
    return {
      params: { locale },
    }
  })
}

const { locale } = Astro.props

// Validate locale
const validLocale: Locale = SUPPORTED_LOCALES.includes(locale as Locale)
  ? locale as Locale
  : 'ro'

// Configure i18n
await configureI18n(validLocale)

const t = (key: string) => {
  const keys = key.split('.')
  let value: any = {
    ro: {
      title: 'Bine ai venit la CLIN-RO',
      subtitle: 'Platforma pentru pagini de landing page personalizate',
      features: 'Funcționalități',
      features_list: ['Brand personalizat', 'Link-uri social media', 'Gestionare ușoară', 'SEO optimizat'],
      adminLogin: 'Admin Login',
      viewExample: 'Vezi Exemplu',
    },
    en: {
      title: 'Welcome to CLIN-RO',
      subtitle: 'Platform for personalized landing pages',
      features: 'Features',
      features_list: ['Custom branding', 'Social media links', 'Easy management', 'SEO optimized'],
      adminLogin: 'Admin Login',
      viewExample: 'View Example',
    },
  }[validLocale]

  for (const k of keys) {
    value = value?.[k]
  }
  return value || key
}
---

<Layout title={`CLIN-RO - ${validLocale === 'ro' ? 'Acasă' : 'Home'}`} locale={validLocale}>
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <!-- Hero Section -->
      <section class="text-center mb-20">
        <div class="inline-block mb-6">
          <span class="text-6xl">🚀</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-red-500 to-orange-500 bg-clip-text text-transparent">
          {t('title')}
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 max-w-2xl mx-auto mb-10">
          {t('subtitle')}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href={`/${validLocale}/admin/login`}
            class="px-8 py-4 bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-800 rounded-xl font-semibold text-lg transition-all duration-300 shadow-lg hover:shadow-red-500/25 hover:scale-105"
          >
            {t('adminLogin')}
          </a>
          <a
            href={`/${validLocale}/urbancarspa`}
            class="px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20 rounded-xl font-semibold text-lg transition-all duration-300 hover:scale-105"
          >
            {t('viewExample')} →
          </a>
        </div>
      </section>

      <!-- Features Section -->
      <section class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-12">{t('features')}</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {t('features_list').map((feature: string, i: number) => (
            <div
              class={`p-6 rounded-2xl bg-gradient-to-br transition-all duration-300 hover:scale-105 ${
                i === 0
                  ? 'from-blue-500/20 to-blue-600/20 border border-blue-500/30 hover:shadow-blue-500/20'
                  : i === 1
                  ? 'from-purple-500/20 to-purple-600/20 border border-purple-500/30 hover:shadow-purple-500/20'
                  : i === 2
                  ? 'from-green-500/20 to-green-600/20 border border-green-500/30 hover:shadow-green-500/20'
                  : 'from-orange-500/20 to-orange-600/20 border border-orange-500/30 hover:shadow-orange-500/20'
              }`}
            >
              <div class="text-3xl mb-3">
                {i === 0 ? '🎨' : i === 1 ? '🔗' : i === 2 ? '⚙️' : '📈'}
              </div>
              <h3 class="font-semibold text-lg">{feature}</h3>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  /* Gradient animations */
  @keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
</style>
