# CLIN-RO Environment Variables
# Copy this file to .env for local development

# Application
ENVIRONMENT=development
APP_URL=http://localhost:4321
ADMIN_URL=http://localhost:4321/admin

# D1 Database (Cloudflare)
# These are set automatically by Wrangler in production
# DATABASE_ID=fd72e9f5-1d81-4a1a-a33f-1be5d52f2a47

# R2 Storage (Cloudflare)
# R2_BUCKET=clin-ro-assets

# Session Security (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-here-change-in-production
CSRF_SECRET=your-csrf-secret-here-change-in-production

# i18n Configuration
DEFAULT_LOCALE=ro
SUPPORTED_LOCALES=ro,en

# Optional: OAuth Providers (for future use)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Analytics
# PLAUSIBLE_DOMAIN=
# PLAUSIBLE_URL=
