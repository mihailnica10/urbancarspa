---
import Layout from '@/layouts/Layout.astro'
import { SUPPORTED_LOCALES, configureI18n, type Locale } from '@/i18n/config'

interface Props {
  locale: string
  slug: string
}

// Static paths for demo tenant
export function getStaticPaths() {
  const locales = SUPPORTED_LOCALES
  const tenants = [
    { slug: 'urbancarspa', name: 'Urban Car Spa', tagline: 'Servicii premium de detailing auto' }
  ]

  return tenants.flatMap(tenant =>
    locales.map(locale => ({
      params: { locale, slug: tenant.slug },
      props: { tenant }
    }))
  )
}

const { locale, slug } = Astro.props
const tenant = Astro.props.tenant

// Validate locale
const validLocale: Locale = SUPPORTED_LOCALES.includes(locale as Locale)
  ? locale as Locale
  : 'ro'

await configureI18n(validLocale)

// Translations
const t = (key: string) => {
  const keys = key.split('.')
  let value: any = {
    ro: {
      bookNow: 'Programează',
      callNow: 'Sună acum',
      followUs: 'Urmărește-ne',
      services: 'Servicii',
      about: 'Despre noi',
      contact: 'Contact',
      language: 'Limbă',
    },
    en: {
      bookNow: 'Book Now',
      callNow: 'Call Now',
      followUs: 'Follow Us',
      services: 'Services',
      about: 'About Us',
      contact: 'Contact',
      language: 'Language',
    },
  }[validLocale]

  for (const k of keys) {
    value = value?.[k]
  }
  return value || key
}

// Theme configuration (would come from DB in production)
const theme = {
  primary: '220 38 38', // Red
  secondary: '39 39 42', // Dark gray
}

// Social links (demo data)
const socialLinks = [
  { platform: 'instagram', url: 'https://instagram.com/urbancarspa', icon: '📷' },
  { platform: 'facebook', url: 'https://facebook.com/urbancarspa', icon: '👍' },
  { platform: 'tiktok', url: 'https://tiktok.com/@urbancarspa', icon: '🎵' },
]

// Custom buttons (demo data)
const customButtons = [
  { label: t('bookNow'), url: '/contact', primary: true },
  { label: t('callNow'), url: 'tel:+40712345678', primary: false },
]
---

<Layout
  title={`${tenant.name} - ${tenant.tagline}`}
  description={tenant.tagline}
  locale={validLocale}
>
  <div class="min-h-screen bg-black text-white">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
      <!-- Animated background -->
      <div class="absolute inset-0 bg-gradient-to-br from-red-950 via-black to-gray-900"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(220,38,38,0.15),transparent_50%)]"></div>

      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-red-600/20 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-red-600/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

      <!-- Content -->
      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
        <!-- Logo placeholder -->
        <div class="mb-8 inline-flex items-center justify-center w-32 h-32 rounded-full bg-gradient-to-br from-red-600 to-red-800 shadow-2xl shadow-red-600/30">
          <span class="text-6xl">🚗</span>
        </div>

        <h1 class="text-6xl md:text-8xl font-bold mb-6 bg-gradient-to-r from-white via-gray-200 to-gray-400 bg-clip-text text-transparent">
          {tenant.name}
        </h1>

        <p class="text-xl md:text-2xl text-gray-300 mb-12 max-w-2xl mx-auto">
          {tenant.tagline}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          {customButtons.map(button => (
            <a
              href={button.url}
              class={`px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 hover:scale-105 ${
                button.primary
                  ? 'bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-800 shadow-lg shadow-red-600/25'
                  : 'bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20'
              }`}
            >
              {button.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Social Links Section -->
    <section class="py-20 px-6 bg-gradient-to-b from-black to-gray-900">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-12 text-gray-200">{t('followUs')}</h2>
        <div class="flex flex-wrap justify-center gap-6">
          {socialLinks.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 px-6 py-4 bg-white/5 hover:bg-white/10 backdrop-blur-sm border border-white/10 rounded-xl transition-all duration-300 hover:scale-105 hover:border-red-600/50"
            >
              <span class="text-2xl">{link.icon}</span>
              <span class="font-medium capitalize">{link.platform}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Language Switcher Footer -->
    <footer class="py-8 px-6 border-t border-white/10 bg-gray-950">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm">
          © {new Date().getFullYear()} {tenant.name}
        </p>
        <div class="flex gap-4">
          {SUPPORTED_LOCALES.map(l => (
            <a
              href={`/${l}/${slug}`}
              class={`text-sm transition-colors ${
                l === validLocale
                  ? 'text-red-500 font-medium'
                  : 'text-gray-500 hover:text-gray-300'
              }`}
            >
              {l === 'ro' ? 'RO' : 'EN'}
            </a>
          ))}
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0) translateX(-50%); }
    50% { transform: translateY(-10px) translateX(-50%); }
  }
</style>
